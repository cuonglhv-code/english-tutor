generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Heavy Data (Content & AI Analysis) ──────────────────────────────────

model EssaySubmission {
  id             String   @id @default(uuid()) @db.Uuid
  user_id        String?  @db.Uuid
  task_type      String
  prompt_text    String   @db.Text
  essay_text     String   @db.Text
  word_count     Int
  language       String   @default("en")
  submitted_at   DateTime @default(now()) @db.Timestamptz(6)
  scoring_method String

  feedback_results FeedbackResult[]
  @@map("essay_submissions")
}

model FeedbackResult {
  id                              String   @id @default(uuid()) @db.Uuid
  submission_id                   String   @db.Uuid
  overall_band                    Decimal  @db.Decimal(3,1)
  task_achievement_band           Decimal  @db.Decimal(3,1)
  coherence_cohesion_band         Decimal  @db.Decimal(3,1)
  lexical_resource_band           Decimal  @db.Decimal(3,1)
  grammatical_range_accuracy_band Decimal  @db.Decimal(3,1)
  feedback_json                   Json     @default("{}")
  generated_at                    DateTime @default(now()) @db.Timestamptz(6)

  submission EssaySubmission @relation(fields: [submission_id], references: [id], onDelete: Cascade)
  @@map("feedback_results")
}

model Question {
  id                      String   @id @default(uuid()) @db.Uuid
  title                   String   @default("Untitled") @db.Text
  task_type               String
  question_type           String?
  prompt_text             String   @db.Text
  image_url               String?
  visual_description      String?  @db.Text
  visual_description_json Json?
  is_published            Boolean  @default(true)
  created_at              DateTime @default(now()) @db.Timestamptz(6)
  
  @@map("questions")
}

