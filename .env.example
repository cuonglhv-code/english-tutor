# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# NEVER expose this in client code. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── Anthropic API ────────────────────────────────────────────────────────────
# Get from https://console.anthropic.com — server-side only
ANTHROPIC_API_KEY=sk-ant-...

# ─── Google Sheets (legacy — optional) ────────────────────────────────────────
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"

# ─── App defaults ─────────────────────────────────────────────────────────────
# Default feedback language ('en' or 'vi')
NEXT_PUBLIC_DEFAULT_LANGUAGE=en
