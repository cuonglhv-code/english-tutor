# ──────────────────────────────────────────────────────────────────────────────
# JAXTINA IELTS — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key...

# ── Anthropic (AI scoring) ────────────────────────────────────────────────────
# Found in: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Resend (email sending — optional) ────────────────────────────────────────
# If not set, admin messages with type='email' fall back to in-app only.
# Free tier: 3,000 emails/month — sufficient for Jaxtina's current scale.
# Get your key at: https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here
