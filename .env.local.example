# ──────────────────────────────────────────────────────────────────────────────
# JAXTINA IELTS — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key...

# ── Anthropic (AI scoring) ────────────────────────────────────────────────────
# Found in: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────────────────────────────────
# MULTI-DATABASE APPROACH (VERCEL/AWS POSTGRES)
# ──────────────────────────────────────────────────────────
# REMOVE — NeonDB / Prisma (no longer used)
# - DATABASE_URL
# - POSTGRES_PRISMA_URL
# - POSTGRES_URL_NON_POOLING
#
# (If these exist in your Vercel dashboard env vars, delete them there too.)

# Set this to your new Vercel Postgres or AWS Postgres connection pool URL
# POSTGRES_PRISMA_URL="postgresql://user:password@aws-rds-endpoint.com:5432/ielts_db?pgbouncer=true"

# ── Resend (email sending — optional) ────────────────────────────────────────
# If not set, admin messages with type='email' fall back to in-app only.
# Free tier: 3,000 emails/month — sufficient for Jaxtina's current scale.
# Get your key at: https://resend.com/api-keys
# Recommended if sending emails via Resend
RESEND_API_KEY=re_your_key_here
